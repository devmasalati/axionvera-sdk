{
  "name": "@axionvera/react",
  "version": "1.0.0",
  "description": "React hooks for Axionvera SDK.",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npx tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "dependencies": {
    "@axionvera/core": "*"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.6",
    "size-limit": "^11.1.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.5",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.6",
    "ts-jest": "^29.2.5",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.5.4"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
